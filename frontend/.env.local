# Leave NEXT_PUBLIC_API_BASE_URL unset so the frontend uses the
# Next.js dev server proxy (configured in next.config.ts -> rewrites).
# This keeps the browser on a same-origin request and avoids CORS errors.
# To bypass the proxy (e.g. when debugging the backend in isolation),
# uncomment the line below.
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
