# Backend
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
DATABASE_URL=sqlite:///./draftmind.db

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# ---- LLM (DeepSeek-V4-Pro via 腾讯云 TokenHub 在线推理) ----
# ★ 模型名必须与 tokenhub「在线推理」页面的「服务 ID」一致
# 推荐：deepseek-v4-pro   （与截图里的服务 ID 完全匹配）
# 备选：deepseek-v4-flash （价格便宜一半）
# 需先开通：deepseek-v4-pro-202606 （原厂直供最新，免费体验不包含）
LLM_PROVIDER=mock
LLM_MODEL=deepseek-v4-pro
LLM_API_KEY=
LLM_API_BASE=https://tokenhub.tencentmaas.com/v1
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=

# ---- News ingestion ----
NEWS_USER_AGENT=Mozilla/5.0 DraftMind/0.1 (Chinese)
NEWS_REFRESH_MINUTES=60
NEWS_MAX_ARTICLES=200

# ---- Free NBA data (balldontlie) ----
# 免费层不需要 key；填上后可以访问 standings / 球员数据
BALLDONTLIE_API_KEY=
BALLDONTLIE_BASE_URL=https://api.balldontlie.io/nba/v1
